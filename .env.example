# ==============================================================================
# Hyrox Companion - Environment Variables
# ==============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required variables are marked with [REQUIRED].
# Optional variables have sensible defaults or enable extra features.
# ==============================================================================

# ------------------------------------------------------------------------------
# Core (Required)
# ------------------------------------------------------------------------------

# [REQUIRED] PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/hyroxtracker"

# [REQUIRED] 32+ character hex key for encrypting tokens at rest (AES-256-GCM)
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ------------------------------------------------------------------------------
# Authentication – Clerk (Optional, enables auth)
# ------------------------------------------------------------------------------
# Create a free project at https://dashboard.clerk.com

# CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# ------------------------------------------------------------------------------
# AI – Google Gemini (Optional, enables AI parsing & coaching)
# ------------------------------------------------------------------------------
# Get a free key at https://aistudio.google.com

# GEMINI_API_KEY=

# ------------------------------------------------------------------------------
# Strava Integration (Optional, enables activity sync)
# ------------------------------------------------------------------------------

# STRAVA_CLIENT_ID=
# STRAVA_CLIENT_SECRET=
# STRAVA_STATE_SECRET=           # CSRF protection; auto-generated if omitted
# APP_URL=http://localhost:5000  # Used for OAuth callback URLs

# ------------------------------------------------------------------------------
# Email – Resend (Optional, enables weekly summaries & reminders)
# ------------------------------------------------------------------------------

# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=fitai.coach <Timmy@fitai.coach>

# ------------------------------------------------------------------------------
# Cron Jobs (Optional)
# ------------------------------------------------------------------------------

# CRON_SECRET=                   # Auth token for /api/v1/cron/emails endpoint

# ------------------------------------------------------------------------------
# Error Tracking – Sentry (Optional)
# ------------------------------------------------------------------------------

# SENTRY_DSN=
# VITE_SENTRY_DSN=

# ------------------------------------------------------------------------------
# RAG Configuration (Optional, has defaults)
# ------------------------------------------------------------------------------

# RAG_CHUNK_SIZE=600             # Characters per chunk for coaching material embeddings
# RAG_CHUNK_OVERLAP=100          # Character overlap between chunks

# ------------------------------------------------------------------------------
# Runtime (Optional, has defaults)
# ------------------------------------------------------------------------------

# NODE_ENV=development           # development | production | test
# PORT=5000
# LOG_LEVEL=info                 # trace | debug | info | warn | error | fatal

# ------------------------------------------------------------------------------
# Development Only
# ------------------------------------------------------------------------------

# ALLOW_DEV_AUTH_BYPASS=true     # Skip auth for local dev (BLOCKED in production)
