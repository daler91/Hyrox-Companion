# ==============================================================================
# fitai.coach - Environment Variables
# ==============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required variables are marked with [REQUIRED].
# Optional variables have sensible defaults or enable extra features.
# ==============================================================================

# ------------------------------------------------------------------------------
# Core (Required)
# ------------------------------------------------------------------------------

# [REQUIRED] PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/fitaicoach"

# [OPTIONAL] Separate PostgreSQL/pgvector connection used by the RAG ingest +
# retrieval pipeline. When unset, the main DATABASE_URL is reused. Production
# splits this onto a Neon pgvector database; local dev can leave it blank.
# VECTOR_DATABASE_URL="postgresql://user:password@localhost:5432/fitaicoach_vector"

# [REQUIRED] 32+ character hex key for encrypting tokens at rest (AES-256-GCM)
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# [REQUIRED IN PRODUCTION] 32+ character hex key for CSRF protection.
# In production this MUST be set and MUST differ from ENCRYPTION_KEY — both
# invariants are enforced at startup. In development/test it may be omitted
# and the middleware falls back to ENCRYPTION_KEY. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CSRF_SECRET=

# [OPTIONAL] Comma-separated list of extra origins allowed by CORS. Localhost
# is always permitted. Only needed when the frontend runs on a different host
# from the API (e.g. a staging domain calling prod).
# ALLOWED_ORIGINS="https://app.example.com,https://staging.example.com"

# ------------------------------------------------------------------------------
# Authentication – Clerk (Optional, enables auth)
# ------------------------------------------------------------------------------
# Create a free project at https://dashboard.clerk.com

# CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# ------------------------------------------------------------------------------
# AI – Google Gemini (Optional, enables AI parsing & coaching)
# ------------------------------------------------------------------------------
# Get a free key at https://aistudio.google.com

# GEMINI_API_KEY=

# Model overrides. Defaults are tuned for fast/cheap parsing + a stronger
# model for full plan suggestions. Change these to pin a specific version
# or to opt-in to a newer release; they are read by server/gemini/* and
# by the image-parse routes.
# GEMINI_MODEL=gemini-2.5-flash-lite
# GEMINI_SUGGESTIONS_MODEL=gemini-3.1-pro-preview
# GEMINI_VISION_MODEL=gemini-2.5-flash

# ------------------------------------------------------------------------------
# Strava Integration (Optional, enables activity sync)
# ------------------------------------------------------------------------------

# STRAVA_CLIENT_ID=
# STRAVA_CLIENT_SECRET=
# STRAVA_STATE_SECRET=           # CSRF protection; auto-generated if omitted
# APP_URL=http://localhost:5000  # Used for OAuth callback URLs

# ------------------------------------------------------------------------------
# Garmin Connect Integration
# ------------------------------------------------------------------------------
# Garmin has no public OAuth app flow — the integration authenticates as the
# end user with their own email+password against Garmin's SSO via the
# @flow-js/garmin-connect library. Credentials are stored encrypted in the
# garmin_connections table. There is NO server-side Garmin client/secret to
# configure here, and the feature is always available when a user enables it
# in Settings. See docs/integrations.md#garmin-connect-integration.

# ------------------------------------------------------------------------------
# Email – Resend (Optional, enables weekly summaries & reminders)
# ------------------------------------------------------------------------------

# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=fitai.coach <Timmy@fitai.coach>

# ------------------------------------------------------------------------------
# Cron Jobs (Optional)
# ------------------------------------------------------------------------------

# CRON_SECRET=                   # Auth token for /api/v1/cron/emails endpoint

# ------------------------------------------------------------------------------
# Web Push / VAPID (Optional, enables PWA push notifications)
# ------------------------------------------------------------------------------
# Generate a keypair with:
#   npx web-push generate-vapid-keys
# When any of these are unset, /api/v1/push/* endpoints return 404
# PUSH_NOT_CONFIGURED and the client simply hides the notification toggle.
# VAPID_EMAIL is the mailto: contact Google/Mozilla push services use if they
# need to reach you about abuse.

# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_EMAIL=mailto:you@example.com

# ------------------------------------------------------------------------------
# Error Tracking – Sentry (Optional)
# ------------------------------------------------------------------------------

# SENTRY_DSN=
# VITE_SENTRY_DSN=

# ------------------------------------------------------------------------------
# RAG Configuration (Optional, has defaults)
# ------------------------------------------------------------------------------

# RAG_CHUNK_SIZE=600             # Characters per chunk for coaching material embeddings
# RAG_CHUNK_OVERLAP=100          # Character overlap between chunks

# ------------------------------------------------------------------------------
# Runtime (Optional, has defaults)
# ------------------------------------------------------------------------------

# NODE_ENV=development           # development | production | test
# PORT=5000
# LOG_LEVEL=info                 # trace | debug | info | warn | error | fatal

# Controls Express "trust proxy" so req.ip does not derive from attacker-
# controlled X-Forwarded-For headers. Accepts "0" (off), "1" (one trusted
# hop — the default, correct for Railway / most PaaS), or "loopback" (only
# local reverse proxies). See CODEBASE_AUDIT.md §2.
# TRUST_PROXY=1

# ------------------------------------------------------------------------------
# Development Only
# ------------------------------------------------------------------------------

# ALLOW_DEV_AUTH_BYPASS=true     # Skip auth for local dev (BLOCKED in production)
