{
  "extends": "./tsconfig.json",
  "include": [
    "client/src/**/*.ts",
    "client/src/**/*.tsx",
    "shared/**/*.ts",
    "server/**/*.ts",
    "**/*.test.ts",
    "**/*.test.tsx",
    "vitest.config.ts",
    "vitest.setup.ts", "vitest.integration.setup.ts"
  ],
  "exclude": [
    "node_modules",
    "build",
    "dist"
  ],
  "compilerOptions": {
    "strict": true,
    "types": ["node", "vite/client", "vitest/globals", "vitest/importMeta", "@testing-library/jest-dom"]
  }
}
